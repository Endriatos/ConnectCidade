# Normaliza quebras de linha para LF em todos os arquivos de texto
* text=auto eol=lf

# Arquivos que devem ser sempre LF
*.py    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.env   text eol=lf
*.txt   text eol=lf

# Arquivos binários — não mexer
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary